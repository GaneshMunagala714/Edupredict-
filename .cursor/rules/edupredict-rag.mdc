│   │   ├── query.py      # RAG query handler
│   │   └── embedding.py  # HuggingFace embeddings
│   └── api.py            # FastAPI endpoints
├── models/
│   ├── predictor.py      # Prediction model
│   └── chroma/           # Vector DB storage
└── requirements.txt
```

## Data Sources to Monitor

